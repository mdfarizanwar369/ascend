NODE_ENV=development
PORT=4000
DATABASE_URL=postgres://ascend:ascend@localhost:5432/ascend
CORS_ORIGIN=http://localhost:3000

# Firebase Admin
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
BOOTSTRAP_OWNER_EMAIL=you@example.com
CRON_SECRET=replace-with-a-long-random-string

# AWS S3
AWS_REGION=ap-southeast-1
AWS_S3_ENDPOINT=
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# AI
AI_PROVIDER=gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
AI_MONTHLY_SPEND_LIMIT_CENTS=5000
AI_MONTHLY_FOOD_ANALYSIS_LIMIT=1000
AI_MONTHLY_CHAT_LIMIT=3000
AI_MONTHLY_WEEKLY_REPORT_LIMIT=500
AI_FOOD_ANALYSIS_ESTIMATED_COST_CENTS=2
AI_CHAT_ESTIMATED_COST_CENTS=1
AI_WEEKLY_REPORT_ESTIMATED_COST_CENTS=2

# ToyyibPay
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
TOYYIBPAY_RETURN_URL=http://localhost:3000/subscription
TOYYIBPAY_CALLBACK_URL=http://localhost:4000/api/v1/webhooks/toyyibpay

# Stripe placeholder for future provider
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
