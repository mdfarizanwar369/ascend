NODE_ENV=development

# Frontend values may also be copied to frontend/.env.local
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# Backend values may also be copied to backend/.env
PORT=4000
DATABASE_URL=postgres://ascend:ascend@localhost:5432/ascend
CORS_ORIGIN=http://localhost:3000
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
BOOTSTRAP_OWNER_EMAIL=you@example.com
CRON_SECRET=replace-with-a-long-random-string

# AWS S3
AWS_REGION=ap-southeast-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=

# OpenAI
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini

# ToyyibPay
TOYYIBPAY_BASE_URL=https://toyyibpay.com
TOYYIBPAY_SECRET_KEY=
TOYYIBPAY_CATEGORY_CODE=
TOYYIBPAY_RETURN_URL=http://localhost:3000/subscription/success
TOYYIBPAY_CALLBACK_URL=http://localhost:4000/api/v1/webhooks/toyyibpay

# Stripe placeholder for future provider
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
